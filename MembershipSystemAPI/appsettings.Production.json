{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "SqliteConnection": "ENV_DATABASE_CONNECTION_STRING"  // This will be read from environment variable ConnectionStrings__SqliteConnection
  },
  "Jwt": {
    "SecretKey": "ENV_JWT_SECRET_KEY",  // This will be read from environment variable Jwt__SecretKey
    "Issuer": "MembershipSystemAPI",
    "Audience": "MembershipSystemClients",
    "ExpiryInHours": 24
  },
  "Database": {
    "ConnectionString": "ENV_DATABASE_CONNECTION_STRING",  // This will be read from environment variable Database__ConnectionString
    "EnableSensitiveDataLogging": false
  },
  "RateLimiting": {
    "LoginAttemptsPerMinute": 5,
    "LoginQueueLimit": 2,
    "RegistrationAttemptsPerHour": 3,
    "GlobalRequestsPerMinute": 100
  },
  "Security": {
    "RequireConfirmedAccount": true,
    "MaxFailedAccessAttempts": 5,
    "LockoutTimeInMinutes": 30,
    "EnableTwoFactor": false
  },
  "Membership": {
    "AutoProcessExpiredMemberships": true,
    "ExpiredMembershipsBatchSize": 1000,
    "ExpiredMembershipsProcessingIntervalMinutes": 30
  }
}